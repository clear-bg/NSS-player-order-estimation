# 1. 環境変数
.env

# 2. Python 環境ファイルとキャッシュ
# 仮想環境フォルダ全体を除外 (Windows/macOS共通)
venv/
.venv/

# Pythonが生成するコンパイル済みファイル
__pycache__/
*.pyc

# ローカルなSQLiteファイルなど（念のため）
*.db
*.session.sql

# 4. OS/IDE 固有のファイル
# macOSのFinderが生成するメタデータファイル
.DS_Store

# --- C# / .NET ---
bin/
obj/
.vs/
*.user
*.suo
*.userprefs

# Windowsが自動生成するサムネイルキャッシュファイル
Thumbs.db

# よく使われるIDEやエディタの一時設定ファイル
*.iml

# ログファイル (Mac)
NssOrderTool/logs
logs/*
起動ログ.log

# SQLite
*.db
*.db-shm
*.db-wal
