<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NssOrderTool.ViewModels"
             xmlns:m="using:NssOrderTool.Models"
             x:Class="NssOrderTool.Views.UserMasterView"
             x:DataType="vm:UserMasterViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

    <Grid RowDefinitions="Auto, Auto" Margin="15">

            <Border Grid.Row="0" Padding="20" Background="#252526" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel Spacing="15">
                    <TextBlock Text="👤 ユーザー＆エイリアス管理" FontSize="18" FontWeight="Bold" Foreground="#DDDDDD"/>
                    <TextBlock Text="正規名（本名）を入力して登録します。別名を同時に登録・追加することも可能です。" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>

                    <Grid ColumnDefinitions="*, *" Width="500" HorizontalAlignment="Left">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="正規名 (必須)" FontWeight="Medium" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding InputUserName}" Watermark="例: Player A" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="別名 / エイリアス (任意)" FontWeight="Medium" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding InputAliasName}" Watermark="例: Aちゃん" />
                        </StackPanel>
                    </Grid>

                    <Button Content="データを保存する" Command="{Binding SaveAsync}" Background="#007ACC" Foreground="White" Padding="20,10" CornerRadius="4" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"  MinHeight="500" Padding="20" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
                <Grid RowDefinitions="Auto, Auto">
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                        <TextBlock Grid.Column="0" Text="📋 登録済みユーザー一覧" FontSize="16" FontWeight="Bold" Foreground="#DDDDDD" VerticalAlignment="Center"/>

                        <ToggleButton Grid.Column="1" Content="✏️ 編集（削除）モード" IsChecked="{Binding IsEditMode}" Padding="10,5" CornerRadius="4"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding UserList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:AliasGroupItem">
                                    <Border Background="#2D2D30" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="Auto, *, Auto">

                                            <Button Grid.Column="0" Content="🗑️" Foreground="#D32F2F" Background="Transparent" VerticalAlignment="Top" Margin="0,0,10,0"
                                                    IsVisible="{Binding $parent[UserControl].((vm:UserMasterViewModel)DataContext).IsEditMode}"
                                                    Command="{Binding $parent[UserControl].((vm:UserMasterViewModel)DataContext).DeleteUserAsync}"
                                                    CommandParameter="{Binding TargetPlayerId}"/>

                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <TextBlock Text="{Binding TargetName}" FontWeight="Bold" FontSize="15" Foreground="#EEEEEE"/>

                                                <ItemsControl ItemsSource="{Binding Aliases}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#3E3E42" CornerRadius="12" Padding="8,4" Margin="0,0,8,4">
                                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                                    <TextBlock Text="{Binding}" Foreground="#CCCCCC" VerticalAlignment="Center"/>

                                                                    <Button Content="✖" Foreground="#D32F2F" Background="Transparent" Padding="2" FontSize="10" VerticalAlignment="Center"
                                                                            IsVisible="{Binding $parent[UserControl].((vm:UserMasterViewModel)DataContext).IsEditMode}"
                                                                            Command="{Binding $parent[UserControl].((vm:UserMasterViewModel)DataContext).DeleteAliasAsync}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
